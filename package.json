{
  "name": "nextjs-fastapi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fastapi-fork-dev": "pip3 install -r api/requirements.txt && python3 -m uvicorn api_fork.index:app --reload",
    "fastapi-dev": "pip3 install -r api/requirements.txt && python3 -m uvicorn api.main:app --reload",
    "dev": "cd web && next dev --turbo",
    "build": "cd web && next build",
    "start": "cd web && next start",
    "lint": "cd web && next lint",
    "test": "echo \"No tests specified\" && exit 0",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.148",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.40",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-form": "^0.1.8",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^1.3.1",
    "@vercel/kv": "^2.0.0",
    "ai": "^5.0.146",
    "autoprefixer": "10.4.14",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "concurrently": "^8.0.1",
    "crypto": "^1.0.1",
    "date-fns": "^4.1.0",
    "eslint": "8.41.0",
    "eslint-config-next": "13.4.4",
    "flowtoken": "^1.0.40",
    "framer-motion": "^11.11.17",
    "geist": "^1.3.1",
    "install": "^0.13.0",
    "langchain": "^1.3.3",
    "lucide-react": "^0.460.0",
    "next": "16.1.6",
    "npm": "^11.12.1",
    "postcss": "8.4.23",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-full-screen": "^1.1.1",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.6.0",
    "react-loading-indicators": "^1.0.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.0.5",
    "sonner": "^1.5.0",
    "streamdown": "^1.6.7",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "types": "link:next-themes/dist/types",
